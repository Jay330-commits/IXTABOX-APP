generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model admins {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String       @unique @db.Uuid
  access_level Int?         @default(1)
  permissions  Json?        @default("[]")
  users        public_users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model bookings {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  box_id             String           @db.Uuid
  payment_id         String           @unique @db.Uuid
  start_date         DateTime         @db.Timestamp(6)
  end_date           DateTime         @db.Timestamp(6)
  lock_pin           Int
  created_at         DateTime         @default(now()) @db.Timestamp(6)
  status             BookingStatus?   @default(Pending)
  display_id         String           @unique
  reported_problems  Json?            @db.Json
  boxes              boxes            @relation(fields: [box_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments           payments         @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  box_returns        box_returns?
  extensions         booking_extensions[]

  @@schema("public")
}

model booking_extensions {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id              String    @db.Uuid
  previous_end_date       DateTime  @db.Timestamp(6)
  new_end_date            DateTime  @db.Timestamp(6)
  previous_lock_pin       Int
  new_lock_pin            Int
  additional_days         Int
  additional_cost         Decimal   @db.Decimal
  payment_id              String?   @db.Uuid
  box_status_at_extension boxStatus?
  created_at              DateTime  @default(now()) @db.Timestamp(6)

  bookings bookings  @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments payments? @relation(fields: [payment_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([booking_id])
  @@index([created_at])
  @@schema("public")
}

model boxes {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stand_id    String     @db.Uuid
  model       boxmodel
  display_id  String     @unique @db.VarChar(12)
  compartment Int?
  status      boxStatus? @default(Active)
  score       BigInt?    @default(0)
  deposit     Decimal?   @db.Decimal
  price       Decimal?   @db.Decimal
  bookings    bookings[]
  stands      stands     @relation(fields: [stand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locks       locks[]

  @@schema("public")
}

model contract_payments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id String    @db.Uuid
  payment_id  String    @unique @db.Uuid
  amount      Decimal   @db.Decimal
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  contracts   contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments    payments  @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model contracts {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributor_id    String              @db.Uuid
  type              ContractType        @default(Leasing)
  start_date        DateTime            @db.Date
  end_date          DateTime            @db.Date
  terms             Json?
  status            ContractStatus?     @default(Active)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  contract_payments contract_payments[]
  distributors      distributors        @relation(fields: [distributor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model customers {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String       @unique @db.Uuid
  loyalty_points Int?         @default(0)
  preferences    Json?
  users          public_users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model distributor_financials {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributor_id String       @db.Uuid
  total_earnings Decimal?     @default(0) @db.Decimal
  pending_payout Decimal?     @default(0) @db.Decimal
  total_bookings Int?         @default(0)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  updated_at     DateTime?    @default(now()) @db.Timestamp(6)
  distributors   distributors @relation(fields: [distributor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model distributors {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                   String                   @unique @db.Uuid
  company_name              String
  reg_number                String
  website                   String?
  contact_person            String
  business_type             String
  years_in_business         String?
  expected_monthly_bookings String?
  marketing_channels        String[]                 @default([])
  business_description      String?
  contract_type             ContractType             @default(Leasing)
  active                    Boolean?                 @default(true)
  created_at                DateTime?                @default(now()) @db.Timestamp(6)
  display_id                String                   @unique @db.VarChar(10)
  contracts                 contracts[]
  distributor_financials    distributor_financials[]
  users                     public_users             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations                 locations[]
  promotions                promotions[]

  @@schema("public")
}

model locations {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributor_id   String             @db.Uuid
  name             String
  address          String?
  coordinates      Json?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  display_id       String             @unique @db.VarChar(10)
  status           status?            @default(Available)
  image            String?
  Region           String?
  distributors     distributors       @relation(fields: [distributor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews          reviews[]
  stands           stands[]
  location_pricing location_pricing[]

  @@schema("public")
}

model location_pricing {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  location_id       String    @db.Uuid
  week              Int
  recommended_price Decimal?  @db.Decimal(10, 2)
  actual_price      Decimal   @db.Decimal(10, 2)

  locations locations @relation(fields: [location_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([location_id, week])
  @@index([location_id])
  @@index([week])
  @@schema("public")
}

model locks {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  device_id String
  box_id    String  @db.Uuid
  company   String
  image     String?
  boxes     boxes   @relation(fields: [box_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model notifications {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String           @db.Uuid
  type        NotificationType @default(Email)
  title       String           @db.VarChar
  message     String?
  read        Boolean?         @default(false)
  created_at  DateTime?        @default(now()) @db.Timestamp(6)
  updated_at  DateTime?        @default(now()) @db.Timestamp(6)
  entity_type String?
  entity_id   String?          @db.Uuid
  users       public_users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model payment_methods {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String       @db.Uuid
  type            String       @db.VarChar
  provider        String?      @db.VarChar
  last_four       String?      @db.Char(1)
  expiration_date DateTime?    @db.Date
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  updated_at      DateTime?    @default(now()) @db.Timestamp(6)
  users           public_users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model payments {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String?                @db.Uuid
  amount             Decimal                @db.Decimal
  currency           String?                @default("SEK")
  completed_at       DateTime?              @db.Timestamp(6)
  charge_id          String                 @unique(map: "payments_payment_id_key")
  status             PaymentStatus?
  bookings           bookings?
  contract_payments  contract_payments?
  booking_extensions booking_extensions[]
  users              public_users?          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@schema("public")
}

model platform_settings {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setting_key String    @unique @db.VarChar
  value       Json?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)

  @@schema("public")
}

model promotions {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributor_id String       @db.Uuid
  code           String       @unique @db.VarChar
  description    String?
  discount_type  DiscountType @default(Percentage)
  discount_value Decimal      @db.Decimal
  max_uses       Int?         @default(0)
  start_date     DateTime     @db.Date
  end_date       DateTime     @db.Date
  active         Boolean?     @default(true)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  updated_at     DateTime?    @default(now()) @db.Timestamp(6)
  distributors   distributors @relation(fields: [distributor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model reviews {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  location_id String       @db.Uuid
  user_id     String       @db.Uuid
  rating      Int
  comment     String?
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  updated_at  DateTime?    @default(now()) @db.Timestamp(6)
  locations   locations    @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       public_users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model stands {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  location_id String    @db.Uuid
  name        String
  capacity    Int?      @default(1)
  features    Json?
  display_id  String    @unique @default(dbgenerated("substr(replace((gen_random_uuid())::text, '-'::text, ''::text), 1, 6)")) @db.Char(6)
  image       String?
  boxes       boxes[]
  locations   locations @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model public_users {
  id              String                @id @db.Uuid
  full_name       String
  email           String                @unique
  phone           String?
  address         Json?
  role            Role                  @default(Guest)
  created_at      DateTime?             @default(now()) @db.Timestamp(6)
  updated_at      DateTime?             @default(now()) @db.Timestamp(6)
  display_id      String                @unique @default(dbgenerated("substr(replace((gen_random_uuid())::text, '-'::text, ''::text), 1, 6)")) @db.Char(6)
  admins          admins?
  customers       customers?
  distributors    distributors?
  notifications   notifications[]
  payment_methods payment_methods[]
  payments        payments[]
  reviews         reviews[]

  @@map("users")
  @@schema("public")
}

model box_returns {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id            String    @unique @db.Uuid
  confirmed_good_status Boolean   @default(false)
  box_front_view        String?   @db.VarChar(500)
  box_back_view         String?   @db.VarChar(500)
  closed_stand_lock     String?   @db.VarChar(500)
  returned_at           DateTime? @db.Timestamp(6)
  created_at            DateTime? @default(now()) @db.Timestamp(6)
  bookings              bookings  @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_box_returns_booking")

  @@index([booking_id], map: "idx_box_returns_booking_id")
  @@schema("public")
}

enum BookingStatus {
  Pending
  Active
  Completed
  Cancelled
  Confirmed
  Upcoming
  Overdue

  @@schema("public")
}

enum ContractStatus {
  Active
  Expired
  Terminated

  @@schema("public")
}

enum ContractType {
  Leasing
  Owning

  @@schema("public")
}

enum DiscountType {
  Percentage
  FixedAmount

  @@schema("public")
}

enum NotificationType {
  Email
  Sms
  Push

  @@schema("public")
}

enum PaymentStatus {
  Pending
  Processing
  Completed
  Failed
  Refunded

  @@schema("public")
}

enum Role {
  Guest
  Customer
  Distributor
  Admin

  @@schema("public")
}

enum boxStatus {
  Active
  Inactive
  Upcoming

  @@schema("public")
}

enum status {
  Available
  Occupied
  Maintenance
  Inactive

  @@schema("public")
}

enum boxmodel {
  Pro_175 @map("Pro 175")
  Pro_190 @map("Pro 190")

  @@schema("public")
}
